# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenRouter (Vision + LLM Extraction)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_EXTRACT_MODEL=openai/gpt-4o-mini

# OpenAI (Whisper Transcription)
OPENAI_API_KEY=sk-your_openai_key

# Google Calendar (Service Account)
# Base64-encoded JSON key file content OR path to mounted JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=base64_encoded_json_here
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Bot
BOT_WEBHOOK_URL=https://your-domain.com
BOT_PORT=8443
TIMEZONE=Europe/Berlin